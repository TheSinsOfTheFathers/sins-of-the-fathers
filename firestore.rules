rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Yardımcı Fonksiyonlar ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }
    
    // --- Genel İçerik Koleksiyonları ---
    match /characters/{characterId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /factions/{factionId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /timeline/{timelineEventId} {
  		allow read: if true;
  		allow write: if isAdmin();
		}
    
    match /lore/{loreEraId} {
    	allow read: if true;
      allow write: if isAdmin();
    }
    
    match /family/{familyId} {
    	allow read: if true;
      allow write: if isAdmin();
    }
    
    match /subscribers/{subscriberId} {
      allow read, update, delete: if false;
      allow create: if true;
    }
    
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId; 
    }

    match /chapters/{chapterId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /admin_settings/{document} {
      allow read, write: if isAdmin();
    }

    // --- Blog Poll Koleksiyonu ---
    match /polls/{pollId} {
      allow read: if true;
      allow create: if true; // Allow anyone to initialize a poll (required for zero-admin setup)
      allow update: if true; // Allow votes
      allow delete: if isAdmin();
    }
  }
}