---
import BaseLayout from "../layouts/BaseLayout.astro";
import Poll from "../components/Poll.astro";

// Decisions can be statically defined or fetched from Sanity/Firestore
// For now: static list of writing decisions with associated polls
const decisions = [
  {
    id: "decision-antagonist-book2",
    title: "Kitap 2: Ana Antagonist Kim Olmalı?",
    context: "Kitap 2'nin senaryosu yazılırken ana antagonist için iki farklı yön ortaya çıktı. Hangisi daha güçlü bir anlatı sağlar?",
    date: "2025",
    pollId: "poll-book2-antagonist",
    pollQuestion: "Kitap 2'nin ana antagonisti kim olmalı?",
    pollOptions: [
      "Roland'ın eski müttefiki, şimdi ihanet etmiş biri",
      "Ravenwood ailesinden tanımadığımız bir üye",
      "Havi'nin geçmişinden gelen birisi",
      "Tamamen yeni, beklenmedik bir karakter"
    ]
  },
  {
    id: "decision-pov-structure",
    title: "POV Yapısı: Tek mi, Çoklu mu?",
    context: "Birinci kitabın POV yapısı Roland odaklıydı. İkinci kitap için okuyucu bakış açısını genişletmek mi, yoksa yoğunlaştırmak mı daha doğru?",
    date: "2025",
    pollId: "poll-pov-structure",
    pollQuestion: "Kitap 2'de anlatım yapısı nasıl olsun?",
    pollOptions: [
      "Yalnızca Roland'ın gözünden (yoğun, odaklı)",
      "Roland + Havi çift POV",
      "3 veya daha fazla POV karakteri",
      "Omnisiyent anlatıcı"
    ]
  },
  {
    id: "decision-ending-type",
    title: "Kitap Serisi: Kaç Cilt?",
    context: "Saga'nın uzunluğunu belirlerken okuyucu deneyimini ön planda tutmak önemli. Siz hangi format seviyorsunuz?",
    date: "2025",
    pollId: "poll-series-length",
    pollQuestion: "TSOF serisi kaç kitap olmalı?",
    pollOptions: [
      "Triloji (3 kitap)",
      "4-5 kitaplık bir seri",
      "6+ kitap (epik saga)",
      "Her kitap kendi içinde tamamlanmış, gevşek bir evren"
    ]
  }
];
---

<BaseLayout title="Yazım Kararları" description="Roman yazım sürecindeki kritik kararlar ve okuyucu anketleri.">
  
  <!-- Page Header -->
  <section class="border-b border-white/5 relative">
    <div class="max-w-7xl mx-auto px-6 py-16 md:py-24">
      <div class="animate-fade-up">
        <div class="flex items-center gap-3 mb-6">
          <span class="gold-line"></span>
          <span class="text-[10px] font-mono text-[#c5a059] uppercase tracking-[0.3em]">Aktif Tartışmalar</span>
        </div>
        <h1 class="font-serif text-5xl md:text-6xl text-white mb-4 leading-tight">
          Yazım <span class="text-[#c5a059]">Kararları</span>
        </h1>
        <p class="text-gray-400 text-lg max-w-xl font-light leading-relaxed">
          Saga'nın gidişatını şekillendiren kritik seçimler. Anketlere katılın, sesi olun.
        </p>
      </div>
    </div>
  </section>

  <!-- Auth Notice -->
  <div id="auth-notice" class="hidden max-w-7xl mx-auto px-6 pt-6">
    <div class="bg-amber-950/30 border border-amber-800/30 px-5 py-3 text-xs font-mono text-amber-400/80 flex items-center gap-3">
      <span>⚠</span>
      <span>Ana siteye giriş yaparsanız oyunuz hesabınıza bağlanır.</span>
      <a href="https://thesinsofthefathers.com/pages/login.html" class="ml-auto underline hover:text-amber-300 transition-colors">Giriş Yap →</a>
    </div>
  </div>

  <!-- Decisions + Polls -->
  <div class="max-w-7xl mx-auto px-6 py-16 space-y-24">
    {decisions.map((decision, i) => (
      <div class={`animate-fade-up-delay-${Math.min(i + 1, 3)}`}>
        <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-start">
          <!-- Decision Context -->
          <div>
            <span class="text-[9px] font-mono text-gray-600 uppercase tracking-widest block mb-4">
              Karar #{String(i + 1).padStart(2, '0')} &nbsp;// &nbsp;{decision.date}
            </span>
            <h2 class="font-serif text-2xl md:text-3xl text-white mb-4 leading-tight">
              {decision.title}
            </h2>
            <div class="w-8 h-px bg-[#c5a059] mb-5"></div>
            <p class="text-gray-400 text-sm leading-relaxed font-light">
              {decision.context}
            </p>
            <p class="mt-4 text-[10px] font-mono text-[#c5a059]/60 uppercase tracking-widest">
              Oy sonuçları herkese açık
            </p>
          </div>

          <!-- Poll -->
          <Poll 
            pollId={decision.pollId}
            question={decision.pollQuestion}
            options={decision.pollOptions}
          />
        </div>
        
        {i < decisions.length - 1 && (
          <div class="mt-16 border-b border-white/5"></div>
        )}
      </div>
    ))}
  </div>

</BaseLayout>

<script>
  // Show auth notice if user is not logged in
  const uid = sessionStorage.getItem('blog_uid');
  const notice = document.getElementById('auth-notice');
  if (!uid && notice) {
    notice.classList.remove('hidden');
  }
</script>
