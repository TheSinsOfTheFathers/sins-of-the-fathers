---
import BaseLayout from "../layouts/BaseLayout.astro";

// Static book data — can be moved to Sanity later
const books = [
  {
    title: "The Sins of the Fathers",
    subtitle: "Book One",
    series: "Ravenwood & Havi Saga",
    status: "published",
    statusLabel: "Yayında",
    year: "2024",
    cover: null, // Add cover image URL when available
    description: "Roland Ravenwood ve Havi'nin hikayesinin başladığı yer. Güç, ihanet ve mirasın gölgesinde geçen bir hesaplaşma.",
    link: "https://thesinsofthefathers.com"
  },
  {
    title: "İkinci Kitap",
    subtitle: "Book Two",
    series: "Ravenwood & Havi Saga",
    status: "writing",
    statusLabel: "Yazılıyor",
    year: "2025 (Beklenen)",
    cover: null,
    description: "Olaylar daha karanlık bir boyuta taşınıyor. Birinci kitabın ardından Roland ve Havi'yi bekleyen yeni tehditler ve ittifaklar.",
    link: null
  },
  {
    title: "Üçüncü Kitap",
    subtitle: "Book Three",
    series: "Ravenwood & Havi Saga",
    status: "upcoming",
    statusLabel: "Planlanıyor",
    year: "Belirsiz",
    cover: null,
    description: "Saga'nın kapanış döngüsü. Tüm iplikler bir araya gelir.",
    link: null
  }
];

const statusConfig: Record<string, { class: string; dot: string; label: string }> = {
  published:  { class: "status-published",  dot: "#22c55e", label: "Yayında" },
  writing:    { class: "status-writing",    dot: "#60a5fa", label: "Yazılıyor" },
  editing:    { class: "status-editing",    dot: "#f59e0b", label: "Düzenleniyor" },
  upcoming:   { class: "status-upcoming",   dot: "#6b7280", label: "Planlanıyor" },
};
---

<BaseLayout title="Gelecek Kitaplar" description="Ravenwood & Havi Saga'sının mevcut ve gelecek kitapları.">

  <!-- Hero -->
  <section class="border-b border-white/5">
    <div class="max-w-7xl mx-auto px-6 py-16 md:py-24 animate-fade-up">
      <div class="flex items-center gap-3 mb-6">
        <span class="gold-line"></span>
        <span class="text-[10px] font-mono text-[#c5a059] uppercase tracking-[0.3em]">Ravenwood & Havi Saga</span>
      </div>
      <h1 class="font-serif text-5xl md:text-6xl text-white mb-4 leading-tight">
        Kitap <span class="text-[#c5a059]">Serisi</span>
      </h1>
      <p class="text-gray-400 text-lg max-w-xl font-light leading-relaxed">
        Mevcut ve planlanan kitaplar. Yazım durumları ve yayın bilgileri.
      </p>
    </div>
  </section>

  <!-- Books List -->
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="space-y-12">
      {books.map((book, i) => {
        const cfg = statusConfig[book.status] || statusConfig.upcoming;
        return (
          <div class={`animate-fade-up-delay-${Math.min(i + 1, 3)}`}>
            <div class="post-card group p-0 md:flex overflow-hidden">
              
              <!-- Cover Placeholder -->
              <div class="md:w-56 md:shrink-0 bg-[#080808] border-b md:border-b-0 md:border-r border-white/5 flex items-center justify-center min-h-[180px] md:min-h-0 relative overflow-hidden">
                {book.cover ? (
                  <img src={book.cover} alt={book.title} class="w-full h-full object-cover" />
                ) : (
                  <div class="text-center p-8">
                    <span class="font-serif text-[#c5a059]/10 text-6xl leading-none block">TSOF</span>
                    <span class="font-mono text-[9px] text-gray-800 uppercase tracking-[0.2em] mt-2 block">Cover TBD</span>
                  </div>
                )}
                <div class="absolute top-4 left-4">
                  <span class={`hud-badge text-[9px] ${cfg.class}`} style={{ borderColor: `${cfg.dot}40`, color: cfg.dot }}>
                    {cfg.label}
                  </span>
                </div>
              </div>

              <!-- Book Info -->
              <div class="flex-1 p-8 md:p-10">
                <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
                  <div>
                    <p class="text-[9px] font-mono text-[#c5a059]/60 uppercase tracking-[0.3em] mb-1">{book.series} — {book.subtitle}</p>
                    <h2 class="font-serif text-3xl text-white group-hover:text-[#c5a059] transition-colors">
                      {book.title}
                    </h2>
                  </div>
                  <div class="text-right shrink-0">
                    <p class="text-[10px] font-mono text-gray-600 uppercase">{book.year}</p>
                  </div>
                </div>

                <div class="w-8 h-px bg-[#c5a059]/40 mb-5"></div>

                <p class="text-gray-400 text-sm leading-relaxed font-light mb-6 max-w-lg">
                  {book.description}
                </p>

                <div class="flex items-center gap-4">
                  {book.link ? (
                    <a href={book.link} target="_blank" rel="noopener" class="text-[10px] font-mono uppercase tracking-widest text-[#c5a059] border border-[#c5a059]/40 px-5 py-2 hover:bg-[#c5a059] hover:text-black transition-all">
                      Siteyi Ziyaret Et →
                    </a>
                  ) : (
                    <span class="text-[10px] font-mono text-gray-700 uppercase tracking-widest border border-white/5 px-5 py-2">
                      Yakında
                    </span>
                  )}
                  
                  <a href="/decisions" class="text-[10px] font-mono text-gray-600 hover:text-[#c5a059] transition-colors uppercase tracking-widest">
                    Kararlara katıl →
                  </a>
                </div>
              </div>
            </div>
          </div>
        );
      })}
    </div>

    <!-- Newsletter/Update notice -->
    <div class="mt-20 border border-dashed border-white/10 p-8 text-center animate-fade-up-delay-3">
      <p class="font-serif text-white text-xl mb-2">Güncellemelerden Haberdar Ol</p>
      <p class="text-gray-500 text-sm font-light mb-6">RSS feed ile tüm yazım güncellemelerini takip edebilirsin.</p>
      <a href="/rss.xml" class="inline-flex items-center gap-2 text-xs font-mono uppercase tracking-widest text-[#c5a059] border border-[#c5a059]/40 px-6 py-2.5 hover:bg-[#c5a059] hover:text-black transition-all">
        RSS Feed'e Abone Ol →
      </a>
    </div>
  </div>

</BaseLayout>
